{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ryd-gate.dev/schemas/device.v1.schema.json",
  "title": "ryd-gate/device/v1",
  "type": "object",
  "properties": {
    "schema": {
      "const": "ryd-gate/device/v1"
    },
    "name": {
      "type": "string"
    },
    "dimensions": {
      "enum": [
        2,
        3
      ]
    },
    "atom_species": {
      "type": "string"
    },
    "allowed_level_structures": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "default_level_structure": {
      "type": "string"
    },
    "min_atom_distance_um": {
      "type": "number"
    },
    "max_atom_num": {
      "type": [
        "integer",
        "null"
      ]
    },
    "max_radial_distance_um": {
      "type": [
        "number",
        "null"
      ]
    },
    "interaction_coeffs": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "channels": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "schema": {
            "const": "ryd-gate/channel/v1"
          }
        },
        "required": [
          "schema"
        ]
      }
    },
    "supports_slm_mask": {
      "type": "boolean"
    },
    "max_sequence_duration_ns": {
      "type": [
        "integer",
        "null"
      ]
    },
    "max_runs": {
      "type": [
        "integer",
        "null"
      ]
    },
    "metadata": {
      "type": "object"
    }
  },
  "required": [
    "schema",
    "name",
    "dimensions",
    "atom_species",
    "allowed_level_structures",
    "default_level_structure",
    "min_atom_distance_um"
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ryd-gate.dev/schemas/observable-config.v1.schema.json",
  "title": "ryd-gate/observable-config/v1",
  "type": "object",
  "properties": {
    "schema": {
      "const": "ryd-gate/observable-config/v1"
    },
    "names": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "times_ns": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      ]
    },
    "every_ns": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "integer",
          "minimum": 1
        }
      ]
    }
  },
  "required": [
    "schema",
    "names"
  ]
}
